# Copy this file to ".env" and fill in the values from your Azure sandbox.
# NEVER commit your real .env file. It is gitignored for a reason.
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-5-5
AZURE_OPENAI_API_VERSION=2024-10-21

# Optional: injected by the platform. GPT-5.5 uses the AZURE_OPENAI_* values above;
# grok/deepseek/mistral live on the Foundry resource below.
AZURE_FOUNDRY_ENDPOINT=
AZURE_FOUNDRY_API_KEY=
MODEL_GPT55_DEPLOYMENT=gpt-5-5
MODEL_GROK43_DEPLOYMENT=xai-grok43
MODEL_DEEPSEEK_V4_PRO_DEPLOYMENT=ds-v4pro
MODEL_MISTRAL_MEDIUM_35_DEPLOYMENT=mstr-med35
